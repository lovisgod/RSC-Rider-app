# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment config — never commit real keys
.env.development
.env.production

# Firebase options (generated by FlutterFire CLI — may contain keys)
# firebase_options.dart  # uncomment if you prefer not to commit this

# Generated files
*.g.dart
*.freezed.dart
